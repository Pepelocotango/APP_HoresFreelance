{
  "name": "horesfreelance",
  "productName": "HoresFreelance",
  "private": true,
  "version": "1.0.0",
  "description": "Aplicació per a autònoms per registrar hores de treball i generar informes.",
  "homepage": "https://github.com/Pepelocotango/APP_HoresFreelance",
  "author": {
    "name": "Pepelocotango",
    "email": "pepelocotango@example.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"vite --port=3000\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build:linux": "ELECTRON=true pnpm run build && electron-builder --linux AppImage",
    "electron:build:win": "set ELECTRON=true && pnpm run build && electron-builder --win nsis",
    "electron:build:mac": "ELECTRON=true pnpm run build && electron-builder --mac dmg",
    "electron:build:all": "ELECTRON=true pnpm run build && electron-builder --linux AppImage --win nsis --mac dmg"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.0.1",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "cat.pepelocotango.horesfreelance",
    "productName": "HoresFreelance",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
